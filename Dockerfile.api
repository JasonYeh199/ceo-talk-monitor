FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements-api.txt pyproject.toml README.md ./
COPY src ./src
COPY main.py config.yaml ./

RUN pip install -r requirements-api.txt && pip install --no-deps -e .

EXPOSE 8000 10000

CMD ["sh", "-c", "uvicorn ceo_talk_monitor.api:app --host 0.0.0.0 --port ${PORT:-8000}"]
